{
  "name": "boarding-house-management-spqm-level-3",
  "version": "3.0.0",
  "description": "Mini project Software Process and Quality Management: Boarding house management Level 3",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "lint": "eslint .",
    "migrate": "node src/models/migrate.js",
    "seed": "node src/models/seed.js",
    "start:auth": "node -e \"process.env.PORT='3001'; require('./src/microservices/authService')\"",
    "start:billing": "node -e \"process.env.PORT='3005'; require('./src/microservices/billingService')\"",
    "start:room": "node -e \"process.env.PORT='3002'; require('./src/microservices/roomService')\"",
    "start:report": "node -e \"process.env.PORT='3003'; require('./src/microservices/reportService')\"",
    "dev:all": "concurrently --kill-others-on-fail --names \"auth,room,billing,report,frontend\" --prefix \"[{name}]\" --prefix-colors \"cyan,green,magenta,yellow,blue\" \"npm run start:auth\" \"npm run start:room\" \"npm run start:billing\" \"npm run start:report\" \"npm run frontend:dev\"",
    "frontend:install": "npm --prefix giaodien install",
    "frontend:dev": "npm --prefix giaodien run dev",
    "frontend:build": "npm --prefix giaodien run build",
    "frontend:lint": "npm --prefix giaodien run lint",
    "test": "jest --coverage",
    "test:integration": "jest tests/app.test.js",
    "test:unit": "jest --testPathIgnorePatterns=tests/app.test.js"
  },
  "keywords": [
    "spqm",
    "express",
    "mysql",
    "jest"
  ],
  "author": "SPQM Team",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.18.1",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.19.2",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.22.6",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "pg-mem": "^3.0.14",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "<rootDir>/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/config/**",
      "!src/microservices/**",
      "!src/models/database.js",
      "!src/models/migrate.js",
      "!src/models/seed.js",
      "!src/server.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  }
}
